<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Fragment>
    <UI Id="CustomUI">
      <UIRef Id="WixUI_Minimal" />

      <Property Id="INSTALLRIBBON" Value="0" />
      <Property Id="INSTALLMENU" Value="0" />
      <Property Id="TEMPLATEDWGPATH" Value="" />
      <Property Id="MEMORYFILEPATH" Value="[AppDataFolder]AcLayerStandardizer\translations.json" />

      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="CustomizationDlg" Order="99" />

    </UI>
  </Fragment>

  <Fragment>
    <UI Id="CustomizationDlg">
      <Text SourceFile="!(loc.CustomizationDlgTitle)" />
      <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="$(loc.InstallerBannerBitmap)" />
      <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Customization Options" />
      <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="Select optional UI customizations." />
      <Control Id="BannerLine" Type="Hyperlink" X="0" Y="44" Width="370" Height="0" />

      <Control Id="LsrNote" Type="Text" X="25" Y="60" Width="320" Height="30" NoPrefix="yes" Text="Note: The app can always be run by typing LSR in the command line, even if no UI customizations are selected." />

      <Control Id="InstallRibbonLabel" Type="Text" X="30" Y="100" Width="300" Height="15" NoPrefix="yes" Text="Install ribbon button (Layer Standardizer tab)" />
      <Control Id="InstallRibbon" Type="CheckBox" X="30" Y="115" Width="300" Height="18" Property="INSTALLRIBBON" CheckBoxValue="1" />

      <Control Id="InstallMenuLabel" Type="Text" X="30" Y="140" Width="300" Height="15" NoPrefix="yes" Text="Install menu item (Custom Apps > Layer Standardizer)" />
      <Control Id="InstallMenu" Type="CheckBox" X="30" Y="155" Width="300" Height="18" Property="INSTALLMENU" CheckBoxValue="1" />

      <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" TabStop="yes" Default="no" Text="&lt; Back">
        <Publish Event="NewDialog" Value="WelcomeDlg" Order="99" />
      </Control>
      <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" TabStop="yes" Default="yes" Text="Next >">
        <Publish Event="NewDialog" Value="ReadyDlg" Order="99" />
      </Control>
      <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" TabStop="yes" Default="no" Cancel="yes" Text="Cancel">
        <Publish Event="SpawnDialog" Value="CancelDlg" Order="99" />
      </Control>
    </UI>
  </Fragment>

  <Fragment>
    <UI Id="ReadyDlg">
      <Text SourceFile="!(loc.ReadyDlgTitle)" />
      <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="$(loc.InstallerBannerBitmap)" />
      <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Ready to Install" />
      <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="Click Install to begin installation." />
      <Control Id="BannerLine" Type="Hyperlink" X="0" Y="44" Width="370" Height="0" />

      <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" TabStop="yes" Default="no" Text="&lt; Back">
        <Publish Event="NewDialog" Value="CustomizationDlg" Order="99" />
      </Control>
      <Control Id="Install" Type="PushButton" X="236" Y="243" Width="56" Height="17" TabStop="yes" Default="yes" Text="Install">
        <Publish Event="DoAction" Value="WixUIValidatePath" Order="99" />
        <Publish Event="NewDialog" Value="ProgressDlg" Order="100" />
      </Control>
      <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" TabStop="yes" Default="no" Cancel="yes" Text="Cancel">
        <Publish Event="SpawnDialog" Value="CancelDlg" Order="99" />
      </Control>
    </UI>
  </Fragment>

</Wix>

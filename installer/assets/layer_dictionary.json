{
  "schemaVersion": 1,
  "description": "Maps layer-name tokens to smart-group tags for the mapping editor's Target-side node filters. This file is user-editable -- add, rename, or retune categories/tokens/thresholds for your own firm's layer standard. See docs/history or memory.md for the design rationale. A category marked \"exclusive\": true is evaluated first; any layer it matches gets ONLY that tag (no discipline tag, no other category) -- used for Annotative, so annotation content never also counts as Floor Plan/Wall/Door/etc. content when filtering.",
  "delimiter": "-",
  "fieldsScanned": 3,
  "foldThreshold": 5,
  "excludedPrefixes": ["ADSK_"],
  "excludedLayers": ["DEFPOINTS", "0___1"],

  "categories": [
    { "name": "Architectural",   "description": "Architectural discipline",                    "tokens": ["A"] },
    { "name": "Structural",      "description": "Structural discipline",                       "tokens": ["S"],            "fallbackGroup": "Engineering" },
    { "name": "Civil",           "description": "Civil discipline",                             "tokens": ["C"],            "fallbackGroup": "Engineering" },
    { "name": "Mechanical",      "description": "Mechanical discipline",                        "tokens": ["M", "MECH"],    "fallbackGroup": "Engineering" },
    { "name": "Electrical",      "description": "Electrical discipline",                        "tokens": ["E", "ELEC"],    "fallbackGroup": "Engineering" },
    { "name": "Plumbing",        "description": "Plumbing discipline",                          "tokens": ["P", "PLMB"],    "fallbackGroup": "Engineering" },
    { "name": "Fire Protection", "description": "Fire protection discipline",                   "tokens": ["FP"],           "fallbackGroup": "Engineering" },
    { "name": "Landscape",       "description": "Landscape architecture discipline / entourage", "tokens": ["L", "LA", "LS"], "fallbackGroup": "Engineering" },
    { "name": "Interior Design", "description": "Interior design discipline (a full consultant designator, distinct from Architectural's own interior-facing sheet content)", "tokens": ["I", "ID"], "fallbackGroup": "Architectural" },

    { "name": "Annotative",        "description": "Dimensions, tags, text, revision clouds, symbols. Exclusive: matched layers get ONLY this tag, never Floor Plan/Wall/Door/etc. too.", "tokens": ["ANNO"], "exclusive": true },
    { "name": "Life Safety",       "description": "Egress/life-safety annotation, including area-of-refuge notation (ARA). Exempt from folding: Annotative claims most LIFESAFETY layers first (it's exclusive), so real counts here are often low, but this stays visible whenever it has any match at all rather than silently disappearing.", "tokens": ["LIFESAFETY", "ARA"], "matchAnywhere": true, "alwaysShow": true },
    { "name": "Area/GFA",          "description": "Area calculations (BOMA, FAR, gross/net)",          "tokens": ["AREA"] },
    { "name": "Ceiling Plan",      "description": "Reflected ceiling plan content",                    "tokens": ["CL", "RCP", "CLNG"] },
    { "name": "Demolition",        "description": "Demolition content",                                "tokens": ["DEMO"] },
    { "name": "Details",           "description": "Detail sheets/blocks",                              "tokens": ["DT", "DTL", "DETAIL"] },
    { "name": "Floor Plan",        "description": "General floor plan content",                        "tokens": ["FL", "FLR"] },
    { "name": "Site Plan",         "description": "Site plan content",                                 "tokens": ["SP", "SITE"] },
    { "name": "Title Block",       "description": "Title block / sheet border content",                "tokens": ["TLBLK", "TBLK"] },
    { "name": "Reference/Non-Plot","description": "Non-plotting reference/scratch content",            "tokens": ["X"] },
    { "name": "Graphics/Color Fills", "description": "Generic color/rendering fills",                  "tokens": ["COL"] },
    { "name": "Coordination Notes","description": "Cross-discipline coordination scratch notes (kept as one flat tag regardless of which discipline suffix follows)", "tokens": ["COORD_NOTES"] },
    { "name": "Hatches/Patterns/Fills", "description": "Hatch/pattern/fill content -- shows up across Details, Floor Plan, and Site Plan alike", "tokens": ["HATCH", "PATT", "PATTERN", "FILL"], "matchAnywhere": true },

    { "name": "Vertical Transportation", "description": "Elevators, escalators, stairs, ramps", "tokens": ["VT"],        "fallbackGroup": "Floor Plan Misc" },
    { "name": "Unit",           "description": "Dwelling-unit-specific content",                "tokens": ["UNIT"],      "fallbackGroup": "Floor Plan Misc" },
    { "name": "Exterior",       "description": "Exterior wall/envelope content",                "tokens": ["EXT"],       "fallbackGroup": "Floor Plan Misc" },
    { "name": "MEP",            "description": "MEP content drawn on architectural floor plans, including plumbing fixtures (FIXTURE/FIXTURES/PLUMBING_FIXTURE/PFIXT are plumbing-fixture abbreviations, folded in here rather than a separate category)", "tokens": ["MEP", "FIXTURE", "FIXTURES", "PLUMBING_FIXTURE", "PFIXT", "PFIX"], "matchAnywhere": true, "fallbackGroup": "Floor Plan Misc" },
    { "name": "Roof",           "description": "Roof plan content",                              "tokens": ["ROOF"],      "fallbackGroup": "Floor Plan Misc" },
    { "name": "Parking",        "description": "Parking layout content",                         "tokens": ["PARKING"],   "fallbackGroup": "Floor Plan Misc" },
    { "name": "ADA",            "description": "Accessibility content",                          "tokens": ["ADA"],       "fallbackGroup": "Floor Plan Misc" },
    { "name": "Equipment",      "description": "Equipment content",                              "tokens": ["EQUIPMENT"], "fallbackGroup": "Floor Plan Misc" },
    { "name": "Casework",       "description": "Casework/millwork",                              "tokens": ["CASEWORK", "CAS"], "fallbackGroup": "Floor Plan Misc" },
    { "name": "Existing",       "description": "Existing-conditions content",                    "tokens": ["EXISTING"],  "fallbackGroup": "Floor Plan Misc" },
    { "name": "Finish",         "description": "Finish content",                                 "tokens": ["FINISH"],    "fallbackGroup": "Floor Plan Misc" },
    { "name": "Furniture",      "description": "Furniture content (FF&E)",                       "tokens": ["FURNITURE", "FURN", "FRN"], "fallbackGroup": "Floor Plan Misc" },
    { "name": "Overhead",       "description": "Overhead/above-ceiling content",                 "tokens": ["OVERHEAD"],  "fallbackGroup": "Floor Plan Misc" },

    { "name": "Wall",   "description": "Wall content, matched anywhere in the layer name regardless of discipline/sheet type", "tokens": ["WALL", "WALLS"], "matchAnywhere": true },
    { "name": "Door",   "description": "Door content, matched anywhere in the layer name",       "tokens": ["DOOR", "DR", "SWNG"], "matchAnywhere": true },
    { "name": "Window", "description": "Window/glazing content, matched anywhere in the layer name", "tokens": ["WIND", "WNDW", "WIN", "GL"], "matchAnywhere": true }
  ]
}

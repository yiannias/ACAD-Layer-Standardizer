<Window x:Class="AcLayerStandardizer.UI.PreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layer Standardization Preview"
        Width="640" Height="480"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas" FontSize="12"
        Background="#1a1a1a"
        Foreground="#e6e6e6">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/AcLayerStandardizer;component/UI/DarkTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14" Margin="0,0,0,8">
      The following layer changes will be applied:
    </TextBlock>

    <ListView Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,0,0,8">
      <ListView.View>
        <GridView>
          <GridViewColumn Width="40">
            <GridViewColumn.Header>
              <CheckBox IsChecked="{Binding SelectAll}" />
            </GridViewColumn.Header>
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" />
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Source Layer" Width="200"
                          DisplayMemberBinding="{Binding SourceLayer}" />
          <GridViewColumn Header="→ Target Layer" Width="200"
                          DisplayMemberBinding="{Binding TargetLayer}" />
          <GridViewColumn Header="Confidence" Width="100"
                          DisplayMemberBinding="{Binding Confidence}" />
        </GridView>
      </ListView.View>
    </ListView>

    <TextBlock Grid.Row="2" FontWeight="Bold" Margin="0,0,0,4"
               Visibility="{Binding UnmatchedVisibility}">
      Unmatched layers (will be ignored):
    </TextBlock>

    <ListView Grid.Row="3" ItemsSource="{Binding Unmatched}"
              Visibility="{Binding UnmatchedVisibility}" Margin="0,0,0,8">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="Layer Name" Width="500"
                          DisplayMemberBinding="{Binding}" />
        </GridView>
      </ListView.View>
    </ListView>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Apply Checked" Width="120" Height="28" Margin="0,0,8,0"
              IsDefault="True" Click="OnApply" />
      <Button Content="Cancel" Width="80" Height="28" IsCancel="True" />
    </StackPanel>
  </Grid>
</Window>

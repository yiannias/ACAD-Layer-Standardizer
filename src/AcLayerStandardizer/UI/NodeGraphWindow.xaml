<Window x:Class="AcLayerStandardizer.UI.NodeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layer Mapping Editor"
        Width="900" Height="650"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#2d2d2d" Padding="12,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Foreground="White" FontSize="14" FontWeight="SemiBold"
                   VerticalAlignment="Center">
          Drag a source layer → to connect. Click a connection to remove it.
          Scroll to zoom. Middle-drag to pan.
        </TextBlock>
        <TextBlock Grid.Column="1" x:Name="ZoomLabel" Foreground="#aaa"
                   FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0">
          100%
        </TextBlock>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ClipToBounds="True" Background="#1e1e1e">
      <Canvas x:Name="GraphCanvas"
              MinWidth="850" MinHeight="500"
              SizeChanged="OnCanvasSizeChanged"
              PreviewMouseLeftButtonDown="OnCanvasPreviewMouseDown"
              PreviewMouseMove="OnCanvasPreviewMouseMove"
              PreviewMouseLeftButtonUp="OnCanvasPreviewMouseUp"
              PreviewMouseWheel="OnCanvasPreviewMouseWheel"
              MouseDown="OnCanvasMouseDown">
        <Canvas.RenderTransform>
          <TransformGroup>
            <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1" />
            <TranslateTransform x:Name="PanTransform" X="0" Y="0" />
          </TransformGroup>
        </Canvas.RenderTransform>
      </Canvas>
    </Grid>

    <Border Grid.Row="2" Background="#2d2d2d" Padding="12,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="StatusBar" Grid.Column="0"
                   Foreground="#aaa" VerticalAlignment="Center">
          Ready
        </TextBlock>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button x:Name="SaveButton" Content="Save Mappings" Width="120" Height="28"
                  Margin="0,0,8,0" IsDefault="True" Click="OnSave" />
          <Button Content="Close" Width="80" Height="28" IsCancel="True" Click="OnClose" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>

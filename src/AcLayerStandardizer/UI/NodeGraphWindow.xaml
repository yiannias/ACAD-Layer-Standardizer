<Window x:Class="AcLayerStandardizer.UI.NodeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nodify="https://miroiu.github.io/nodify"
        xmlns:local="clr-namespace:AcLayerStandardizer.UI"
        Title="Layer Standardizer: Layer Mapping Editor"
        Width="900" Height="650"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="12">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Nodify;component/Themes/Dark.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <local:BooleanToVisibilityConverter x:Key="BoolToVis" />
      <local:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />
      <local:ColorStringToBrushConverter x:Key="ColorStringToBrush" />

      <!-- Layer node style: base dark, slate-blue when mapped -->
      <Style TargetType="nodify:StateNode">
        <Setter Property="Background" Value="#424242" />
        <Setter Property="BorderBrush" Value="#666" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HighlightBrush" Value="Transparent" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="nodify:StateNode">
              <Grid Width="178" Height="30">
                <Border x:Name="NodeBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        Width="170"
                        HorizontalAlignment="Center"
                        ClipToBounds="True">
                  <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>
                <Ellipse x:Name="SourceConnector"
                         Width="8" Height="8"
                         Fill="{Binding ConnectorColor, Converter={StaticResource ColorStringToBrush}}"
                         Stroke="#555" StrokeThickness="0.5"
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         Margin="0,0,-4,0"
                         Visibility="{Binding IsSource, Converter={StaticResource BoolToVis}}" />
                <Ellipse x:Name="TargetConnector"
                         Width="8" Height="8"
                         Fill="{Binding ConnectorColor, Converter={StaticResource ColorStringToBrush}}"
                         Stroke="#555" StrokeThickness="0.5"
                         HorizontalAlignment="Left" VerticalAlignment="Center"
                         Margin="-4,0,0,0"
                         Visibility="{Binding IsSource, Converter={StaticResource InvBoolToVis}}" />
              </Grid>
              <ControlTemplate.Triggers>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <DataTrigger Binding="{Binding IsMapped}" Value="True">
            <Setter Property="Background" Value="#4a6b8a" />
          </DataTrigger>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="BorderBrush" Value="#fff" />
            <Setter Property="BorderThickness" Value="2" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Connection lines: color-coded by match source, glowing on connect -->
      <Style TargetType="nodify:Connection">
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="Stroke" Value="#7c4dff" />
        <Setter Property="Effect">
          <Setter.Value>
            <DropShadowEffect BlurRadius="0" Opacity="0" Color="Transparent" ShadowDepth="0" />
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <DataTrigger Binding="{Binding MatchSource}" Value="ExactName">
            <Setter Property="Stroke" Value="#00e676" />
            <Setter Property="StrokeDashArray" Value="0" />
            <Setter Property="Effect">
              <Setter.Value>
                <DropShadowEffect BlurRadius="12" Opacity="0.8" Color="#00e676" ShadowDepth="0" />
              </Setter.Value>
            </Setter>
          </DataTrigger>
          <DataTrigger Binding="{Binding MatchSource}" Value="Memory">
            <Setter Property="Stroke" Value="#448aff" />
            <Setter Property="StrokeDashArray" Value="4,3" />
            <Setter Property="Effect">
              <Setter.Value>
                <DropShadowEffect BlurRadius="12" Opacity="0.8" Color="#448aff" ShadowDepth="0" />
              </Setter.Value>
            </Setter>
          </DataTrigger>
          <DataTrigger Binding="{Binding MatchSource}" Value="Heuristic">
            <Setter Property="Stroke" Value="#ffd740" />
            <Setter Property="StrokeDashArray" Value="4,3" />
            <Setter Property="Effect">
              <Setter.Value>
                <DropShadowEffect BlurRadius="12" Opacity="0.8" Color="#ffd740" ShadowDepth="0" />
              </Setter.Value>
            </Setter>
          </DataTrigger>
          <DataTrigger Binding="{Binding MatchSource}" Value="Manual">
            <Setter Property="Stroke" Value="#7c4dff" />
            <Setter Property="StrokeDashArray" Value="0" />
            <Setter Property="Effect">
              <Setter.Value>
                <DropShadowEffect BlurRadius="12" Opacity="0.8" Color="#7c4dff" ShadowDepth="0" />
              </Setter.Value>
            </Setter>
          </DataTrigger>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Stroke" Value="#ef5350" />
            <Setter Property="StrokeDashArray" Value="0" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Modern button style -->
      <Style x:Key="ModernButton" TargetType="Button">
        <Setter Property="Background" Value="#3a3a3a" />
        <Setter Property="Foreground" Value="#eee" />
        <Setter Property="BorderBrush" Value="#555" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="6"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#4a4a4a" />
                  <Setter Property="BorderBrush" Value="#888" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Background" Value="#2a2a2a" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Grid background brush -->
      <DrawingBrush x:Key="GridBrush"
                    Viewport="0,0,24,24" ViewportUnits="Absolute"
                    TileMode="Tile">
        <DrawingBrush.Drawing>
          <DrawingGroup>
            <GeometryDrawing Geometry="M 0,0 L 0,24 M 0,0 L 24,0">
              <GeometryDrawing.Pen>
                <Pen Brush="#22ffffff" Thickness="1" />
              </GeometryDrawing.Pen>
            </GeometryDrawing>
          </DrawingGroup>
        </DrawingBrush.Drawing>
      </DrawingBrush>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Nodify editor area -->
    <Grid Grid.Row="0" Background="#1e1e1e">
      <Rectangle Fill="{StaticResource GridBrush}" Opacity="0.12" IsHitTestVisible="False" />

      <nodify:NodifyEditor x:Name="Editor"
                            Background="Transparent"
                            ItemsSource="{Binding Nodes}"
                            Connections="{Binding Connections}"
                            PendingConnection="{Binding PendingConnection}"
                            RemoveConnectionCommand="{Binding RemoveConnectionCommand}"
                            DisconnectConnectorCommand="{Binding DisconnectConnectorCommand}"
                            MinWidth="800" MinHeight="400">

        <nodify:NodifyEditor.ItemContainerStyle>
          <Style TargetType="nodify:ItemContainer">
            <Setter Property="Location" Value="{Binding Location}" />
            <Setter Property="ActualSize" Value="{Binding Size, Mode=OneWayToSource}" />
            <Setter Property="IsDraggable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
          </Style>
        </nodify:NodifyEditor.ItemContainerStyle>

        <nodify:NodifyEditor.ItemTemplate>
          <DataTemplate DataType="{x:Type local:LayerNodeViewModel}">
            <nodify:StateNode IsConnected="True" Content="{Binding}">
              <nodify:StateNode.ContentTemplate>
                <DataTemplate DataType="{x:Type local:LayerNodeViewModel}">
                  <TextBlock Text="{Binding Name}"
                             Foreground="#ddd"
                             FontFamily="Fira Sans"
                             FontSize="11"
                             FontWeight="Medium"
                             TextTrimming="CharacterEllipsis"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </nodify:StateNode.ContentTemplate>
            </nodify:StateNode>
          </DataTemplate>
        </nodify:NodifyEditor.ItemTemplate>

        <nodify:NodifyEditor.ConnectionTemplate>
          <DataTemplate DataType="{x:Type local:LayerConnectionViewModel}">
            <nodify:Connection Source="{Binding Source.Anchor, Mode=OneWay}"
                                Target="{Binding Target.Anchor, Mode=OneWay}"
                                PreviewMouseDown="OnConnectionPreviewMouseDown" />
          </DataTemplate>
        </nodify:NodifyEditor.ConnectionTemplate>

        <nodify:NodifyEditor.PendingConnectionTemplate>
          <DataTemplate DataType="{x:Type local:PendingConnectionViewModel}">
            <nodify:PendingConnection StartedCommand="{Binding StartCommand}"
                                      CompletedCommand="{Binding FinishCommand}"
                                      Stroke="#FFE6A817"
                                      StrokeThickness="2.5"
                                      StrokeDashArray="4,3" />
          </DataTemplate>
        </nodify:NodifyEditor.PendingConnectionTemplate>
      </nodify:NodifyEditor>
    </Grid>

    <!-- Status bar + action buttons -->
    <Border Grid.Row="1" Background="#2d2d2d" Padding="12,10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Guidance line -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Foreground="#aaa" FontSize="11"
                   Text="Drag from a source → standard layer to map. Click a connection to remove it. Scroll to zoom. Middle-drag to pan."
                   Margin="0,0,0,4" />

        <!-- Status + action buttons -->
        <TextBlock x:Name="StatusText" Grid.Row="1" Grid.Column="0"
                   Foreground="#aaa" FontSize="11"
                   VerticalAlignment="Center">
          Ready
        </TextBlock>
        <Button Grid.Row="1" Grid.Column="1" Content="Apply Mappings"
                Style="{StaticResource ModernButton}"
                Margin="0,0,8,0"
                Click="OnApply" />
        <Button Grid.Row="1" Grid.Column="2" Content="Apply &amp; Save"
                Style="{StaticResource ModernButton}"
                Foreground="White"
                IsDefault="True"
                Click="OnApplyAndSave">
          <Button.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#7c4dff" Offset="0.0" />
              <GradientStop Color="#536dfe" Offset="1.0" />
            </LinearGradientBrush>
          </Button.Background>
          <Button.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#651fff" Offset="0.0" />
              <GradientStop Color="#3d5afe" Offset="1.0" />
            </LinearGradientBrush>
          </Button.BorderBrush>
          <Button.Effect>
            <DropShadowEffect Color="#7c4dff" Opacity="0.35" BlurRadius="10" ShadowDepth="3" />
          </Button.Effect>
        </Button>
      </Grid>
    </Border>
  </Grid>
</Window>
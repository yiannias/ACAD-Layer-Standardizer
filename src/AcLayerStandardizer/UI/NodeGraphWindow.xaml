<Window x:Class="AcLayerStandardizer.UI.NodeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nodify="https://miroiu.github.io/nodify"
        xmlns:local="clr-namespace:AcLayerStandardizer.UI"
        Title="Layer Standardizer: Layer Mapping Editor"
        Width="1200" Height="650"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="12"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Nodify;component/Themes/Dark.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <local:BooleanToVisibilityConverter x:Key="BoolToVis" />
      <local:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />
      <local:ColorStringToBrushConverter x:Key="ColorStringToBrush" />
      <local:BooleanToOpacityConverter x:Key="BoolToOpacity" />

      <!-- Shadow for floating panel -->
      <DropShadowEffect x:Key="PanelShadow"
                        Color="#000"
                        Opacity="0.5"
                        BlurRadius="12"
                        ShadowDepth="3" />

      <!-- Filter toggle button style with animated transitions -->
      <Style x:Key="FilterToggleButton" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ToggleButton">
              <Border x:Name="Bg"
                      Background="{TemplateBinding Background}"
                      CornerRadius="4"
                      BorderThickness="0">
                <TextBlock x:Name="Tb"
                           Text="{TemplateBinding Content}"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Trigger.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Bg"
                                         Storyboard.TargetProperty="Opacity"
                                         To="1" Duration="0:0:0.2" />
                        <ColorAnimation Storyboard.TargetName="Tb"
                                        Storyboard.TargetProperty="Foreground.Color"
                                        To="#222" Duration="0:0:0.2" />
                      </Storyboard>
                    </BeginStoryboard>
                  </Trigger.EnterActions>
                  <Trigger.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Bg"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.3" Duration="0:0:0.2" />
                        <ColorAnimation Storyboard.TargetName="Tb"
                                        Storyboard.TargetProperty="Foreground.Color"
                                        To="White" Duration="0:0:0.2" />
                      </Storyboard>
                    </BeginStoryboard>
                  </Trigger.ExitActions>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bg" Property="Opacity" Value="0.85" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Layer node style: base dark, target nodes thicken border when mapped -->
      <Style TargetType="nodify:StateNode">
        <Setter Property="Background" Value="#424242" />
        <Setter Property="BorderBrush" Value="#666" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HighlightBrush" Value="Transparent" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="nodify:StateNode">
              <Grid Width="280" Height="30">
                <Border x:Name="NodeBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                  <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>
                <Ellipse x:Name="SourceConnector"
                         Width="8" Height="8"
                         Fill="{Binding ConnectorColor, Converter={StaticResource ColorStringToBrush}}"
                         Stroke="#555" StrokeThickness="0.5"
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         Margin="0,0,-4,0"
                         Visibility="{Binding IsSource, Converter={StaticResource BoolToVis}}" />
                <Ellipse x:Name="TargetConnector"
                         Width="8" Height="8"
                         Fill="{Binding ConnectorColor, Converter={StaticResource ColorStringToBrush}}"
                         Stroke="#555" StrokeThickness="0.5"
                         HorizontalAlignment="Left" VerticalAlignment="Center"
                         Margin="-4,0,0,0"
                         Visibility="{Binding IsSource, Converter={StaticResource InvBoolToVis}}" />
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <MultiDataTrigger>
            <MultiDataTrigger.Conditions>
              <Condition Binding="{Binding IsSource}" Value="False" />
              <Condition Binding="{Binding IsMapped}" Value="True" />
            </MultiDataTrigger.Conditions>
            <Setter Property="BorderBrush" Value="#fff" />
            <Setter Property="BorderThickness" Value="3" />
          </MultiDataTrigger>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="BorderBrush" Value="#fff" />
            <Setter Property="BorderThickness" Value="2" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Connection lines: color + dash are bound directly on the element via Stroke/StrokeDashCollection -->
      <Style TargetType="nodify:Connection">
        <Setter Property="StrokeThickness" Value="2" />
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Stroke" Value="#ef5350" />
            <Setter Property="StrokeDashArray" Value="0" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Modern button style -->
      <Style x:Key="ModernButton" TargetType="Button">
        <Setter Property="Background" Value="#3a3a3a" />
        <Setter Property="Foreground" Value="#eee" />
        <Setter Property="BorderBrush" Value="#555" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="6"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#4a4a4a" />
                  <Setter Property="BorderBrush" Value="#888" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Background" Value="#2a2a2a" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Grid background brush -->
        <DrawingBrush x:Key="GridBrush"
                      Viewport="0,0,24,24" ViewportUnits="Absolute"
                      TileMode="Tile">
          <DrawingBrush.Drawing>
            <DrawingGroup>
              <GeometryDrawing Geometry="M 0,0 L 0,24 M 0,0 L 24,0">
                <GeometryDrawing.Pen>
                  <Pen Brush="#22ffffff" Thickness="1" />
                </GeometryDrawing.Pen>
              </GeometryDrawing>
            </DrawingGroup>
          </DrawingBrush.Drawing>
        </DrawingBrush>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Nodify editor area -->
    <Grid Grid.Row="0" Background="#141414">
      <Rectangle Fill="{StaticResource GridBrush}" Opacity="0.15" IsHitTestVisible="False" />

      <nodify:NodifyEditor x:Name="Editor"
                            Background="Transparent"
                            ItemsSource="{Binding Nodes}"
                            Connections="{Binding Connections}"
                            PendingConnection="{Binding PendingConnection}"
                            RemoveConnectionCommand="{Binding RemoveConnectionCommand}"
                            DisconnectConnectorCommand="{Binding DisconnectConnectorCommand}"
                            MinWidth="1500" MinHeight="400"
                            AutoPanEdgeDistance="40"
                            AutoPanSpeed="30"
                            Focusable="True">

        <nodify:NodifyEditor.ItemContainerStyle>
          <Style TargetType="nodify:ItemContainer">
            <Setter Property="Location" Value="{Binding Location}" />
            <Setter Property="ActualSize" Value="{Binding Size, Mode=OneWayToSource}" />
            <Setter Property="IsDraggable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
          </Style>
        </nodify:NodifyEditor.ItemContainerStyle>

        <nodify:NodifyEditor.ItemTemplate>
          <DataTemplate DataType="{x:Type local:LayerNodeViewModel}">
            <nodify:StateNode IsConnected="True" Content="{Binding}">
              <nodify:StateNode.ContentTemplate>
                <DataTemplate DataType="{x:Type local:LayerNodeViewModel}">
                  <TextBlock Text="{Binding Name}"
                             Foreground="#ddd"
                             FontFamily="Fira Sans"
                             FontSize="11"
                             FontWeight="Medium"
                             TextTrimming="CharacterEllipsis"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </nodify:StateNode.ContentTemplate>
            </nodify:StateNode>
          </DataTemplate>
        </nodify:NodifyEditor.ItemTemplate>

        <nodify:NodifyEditor.ConnectionTemplate>
          <DataTemplate DataType="{x:Type local:LayerConnectionViewModel}">
            <nodify:Connection Source="{Binding Source.Anchor, Mode=OneWay}"
                                Target="{Binding Target.Anchor, Mode=OneWay}"
                                Stroke="{Binding Stroke, Converter={StaticResource ColorStringToBrush}}"
                                StrokeDashArray="{Binding StrokeDashCollection}"
                                PreviewMouseDown="OnConnectionPreviewMouseDown"
                                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
          </DataTemplate>
        </nodify:NodifyEditor.ConnectionTemplate>

        <nodify:NodifyEditor.PendingConnectionTemplate>
          <DataTemplate DataType="{x:Type local:PendingConnectionViewModel}">
            <nodify:PendingConnection StartedCommand="{Binding StartCommand}"
                                      CompletedCommand="{Binding FinishCommand}"
                                      Stroke="#FFE6A817"
                                      StrokeThickness="2.5"
                                      StrokeDashArray="4,3" />
          </DataTemplate>
        </nodify:NodifyEditor.PendingConnectionTemplate>
      </nodify:NodifyEditor>

      <!-- Floating filter panel (top-left, legend + toggles) -->
      <Border Grid.Row="0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="25,25,0,0"
              Padding="14,12"
              CornerRadius="8"
              Background="#882a2a2a"
              BorderBrush="#999"
              BorderThickness="3"
              Panel.ZIndex="10"
              Effect="{StaticResource PanelShadow}">
        <StackPanel Orientation="Vertical">
          <TextBlock Text="Legend"
                     FontSize="16" FontWeight="Bold"
                     Foreground="#fff" />
          <TextBlock Text="Visibility Toggle"
                     FontSize="10"
                     Foreground="#777"
                     Margin="0,0,0,10" />

          <ToggleButton Content="Exact Match"
                        Background="#8bc34a"
                        IsChecked="{Binding IsExactNameVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Margin="0,0,0,5"
                        Style="{StaticResource FilterToggleButton}" />

          <ToggleButton Content="Memory Match"
                        Background="#448aff"
                        IsChecked="{Binding IsMemoryMatchVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Margin="0,0,0,5"
                        Style="{StaticResource FilterToggleButton}" />

          <ToggleButton Content="Heuristic Match"
                        Background="#ffd740"
                        IsChecked="{Binding IsHeuristicMatchVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Margin="0,0,0,5"
                        Style="{StaticResource FilterToggleButton}" />

          <ToggleButton Content="Manual Match"
                        Background="#7c4dff"
                        IsChecked="{Binding IsManualMatchVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Margin="0,0,0,5"
                        Style="{StaticResource FilterToggleButton}" />

          <ToggleButton Content="Unmatched"
                        Background="#888"
                        IsChecked="{Binding IsUnmatchedVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Style="{StaticResource FilterToggleButton}" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Status bar + action buttons -->
    <Border Grid.Row="1" Background="#2d2d2d" Padding="12,10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Guidance line -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Foreground="#aaa" FontSize="11"
                   Text="Drag from a source → standard layer to map. Click a connection to remove it. Scroll to zoom. Middle-drag to pan."
                   Margin="0,0,0,4" />

        <!-- Status + action buttons -->
        <TextBlock x:Name="StatusText" Grid.Row="1" Grid.Column="0"
                   Foreground="#aaa" FontSize="11"
                   VerticalAlignment="Center">
          Ready
        </TextBlock>
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Foreground="#555" FontSize="10"
                    VerticalAlignment="Center">2027-07-08.v2 (ALPHA)</TextBlock>
        <Button Grid.Row="1" Grid.Column="1" Content="Apply Mappings"
                Style="{StaticResource ModernButton}"
                Margin="0,0,8,0"
                Click="OnApply" />
        <Button Grid.Row="1" Grid.Column="2" Content="Apply &amp; Save"
                Style="{StaticResource ModernButton}"
                Foreground="White"
                IsDefault="True"
                Click="OnApplyAndSave">
          <Button.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#7c4dff" Offset="0.0" />
              <GradientStop Color="#536dfe" Offset="1.0" />
            </LinearGradientBrush>
          </Button.Background>
          <Button.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#651fff" Offset="0.0" />
              <GradientStop Color="#3d5afe" Offset="1.0" />
            </LinearGradientBrush>
          </Button.BorderBrush>
          <Button.Effect>
            <DropShadowEffect Color="#7c4dff" Opacity="0.35" BlurRadius="10" ShadowDepth="3" />
          </Button.Effect>
        </Button>
      </Grid>
    </Border>
  </Grid>
</Window>
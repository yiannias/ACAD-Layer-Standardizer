<Window x:Class="AcLayerStandardizer.UI.NodeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nodify="https://miroiu.github.io/nodify"
        xmlns:local="clr-namespace:AcLayerStandardizer.UI"
        Title="Layer Standardizer: Layer Mapping Editor"
        Width="1200" Height="650"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="12"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        PreviewMouseDown="Window_PreviewMouseDown">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Nodify;component/Themes/Dark.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <local:BooleanToVisibilityConverter x:Key="BoolToVis" />
      <local:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />
      <local:ColorStringToBrushConverter x:Key="ColorStringToBrush" />
      <local:BooleanToOpacityConverter x:Key="BoolToOpacity" />
      <local:SubtractDoubleConverter x:Key="SubtractDouble" />

      <!-- Shadow for floating panel -->
      <DropShadowEffect x:Key="PanelShadow"
                        Color="#000"
                        Opacity="0.5"
                        BlurRadius="12"
                        ShadowDepth="3" />

      <!-- Pill-shaped scrollbar (rounded track + rounded thumb), applied to
           every ScrollBar in the window rather than just the Target Filter
           panel's, since it's a design-system choice not a one-off. Only the
           vertical case is styled; this app has no horizontal scrolling UI. -->
      <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid>
                <Border CornerRadius="5" Background="#2a2a2a" />
                <Track Name="PART_Track" IsDirectionReversed="True" Margin="2">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                  </Track.DecreaseRepeatButton>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                  </Track.IncreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb>
                      <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                          <Border x:Name="ThumbBorder" Background="#777" CornerRadius="3" />
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="ThumbBorder" Property="Background" Value="#999" />
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Thumb.Template>
                    </Thumb>
                  </Track.Thumb>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Filter toggle button style with animated transitions -->
      <Style x:Key="FilterToggleButton" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ToggleButton">
              <Border x:Name="Bg"
                      Background="{TemplateBinding Background}"
                      CornerRadius="4"
                      BorderThickness="0">
                <TextBlock x:Name="Tb"
                           Text="{TemplateBinding Content}"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Trigger.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Bg"
                                         Storyboard.TargetProperty="Opacity"
                                         To="1" Duration="0:0:0.2" />
                        <ColorAnimation Storyboard.TargetName="Tb"
                                        Storyboard.TargetProperty="Foreground.Color"
                                        To="#222" Duration="0:0:0.2" />
                      </Storyboard>
                    </BeginStoryboard>
                  </Trigger.EnterActions>
                  <Trigger.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Bg"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.3" Duration="0:0:0.2" />
                        <ColorAnimation Storyboard.TargetName="Tb"
                                        Storyboard.TargetProperty="Foreground.Color"
                                        To="White" Duration="0:0:0.2" />
                      </Storyboard>
                    </BeginStoryboard>
                  </Trigger.ExitActions>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bg" Property="Opacity" Value="0.85" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Slide-toggle style for property matching switches -->
      <Style x:Key="SlideToggle" TargetType="ToggleButton">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ToggleButton">
              <Border x:Name="Track"
                      Width="40" Height="20"
                      CornerRadius="10"
                      Background="#555"
                      SnapsToDevicePixels="True">
                <Border x:Name="Thumb"
                        Width="16" Height="16"
                        CornerRadius="8"
                        Background="#ddd"
                        HorizontalAlignment="Left"
                        Margin="2,0,0,0"
                        RenderTransformOrigin="0.5,0.5">
                  <Border.RenderTransform>
                    <TranslateTransform />
                  </Border.RenderTransform>
                </Border>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Trigger.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <ColorAnimation Storyboard.TargetName="Track"
                                        Storyboard.TargetProperty="Background.Color"
                                        To="#4682b4" Duration="0:0:0.15" />
                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                        Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)"
                                        To="20" Duration="0:0:0.15" />
                      </Storyboard>
                    </BeginStoryboard>
                  </Trigger.EnterActions>
                  <Trigger.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <ColorAnimation Storyboard.TargetName="Track"
                                        Storyboard.TargetProperty="Background.Color"
                                        To="#555" Duration="0:0:0.15" />
                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                        Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)"
                                        To="0" Duration="0:0:0.15" />
                      </Storyboard>
                    </BeginStoryboard>
                  </Trigger.ExitActions>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Layer node style: base dark, target nodes thicken border when mapped -->
      <Style TargetType="nodify:StateNode">
        <Setter Property="Background" Value="{Binding BackgroundColor, Converter={StaticResource ColorStringToBrush}}" />
        <Setter Property="BorderBrush" Value="#666" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HighlightBrush" Value="Transparent" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="nodify:StateNode">
              <Grid Width="280" Height="30">
                <Border x:Name="NodeBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                  <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>
                <Ellipse x:Name="SourceConnector"
                         Width="8" Height="8"
                         Fill="{Binding ConnectorColor, Converter={StaticResource ColorStringToBrush}}"
                         Stroke="#555" StrokeThickness="0.5"
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         Margin="0,0,-4,0"
                         Visibility="{Binding IsSource, Converter={StaticResource BoolToVis}}" />
                <Ellipse x:Name="TargetConnector"
                         Width="8" Height="8"
                         Fill="{Binding ConnectorColor, Converter={StaticResource ColorStringToBrush}}"
                         Stroke="#555" StrokeThickness="0.5"
                         HorizontalAlignment="Left" VerticalAlignment="Center"
                         Margin="-4,0,0,0"
                         Visibility="{Binding IsSource, Converter={StaticResource InvBoolToVis}}" />
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <!-- Border hierarchy, weakest to strongest. Later triggers win when
             more than one is active at once, so declaration order below IS
             the priority order: Hover < Mapped < Selected. Selected uses an
             accent (orange) unrelated to any match-type hue so it can never
             be confused with a Heuristic-match connector/node (both used to
             render as near-identical gold, #FFD700 vs #ffd740). -->
        <Style.Triggers>
          <DataTrigger Binding="{Binding IsSource}" Value="False">
            <Setter Property="Background" Value="{Binding BackgroundColor, Converter={StaticResource ColorStringToBrush}}" />
          </DataTrigger>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="BorderBrush" Value="#ccc" />
            <Setter Property="BorderThickness" Value="1" />
          </Trigger>
          <MultiDataTrigger>
            <MultiDataTrigger.Conditions>
              <Condition Binding="{Binding IsSource}" Value="False" />
              <Condition Binding="{Binding IsMapped}" Value="True" />
            </MultiDataTrigger.Conditions>
            <Setter Property="BorderBrush" Value="#e0e0e0" />
            <Setter Property="BorderThickness" Value="2" />
          </MultiDataTrigger>
          <DataTrigger Binding="{Binding IsSelected}" Value="True">
            <Setter Property="BorderBrush" Value="#d95926" />
            <Setter Property="BorderThickness" Value="3" />
          </DataTrigger>
        </Style.Triggers>
      </Style>

      <!-- Connection line style. KEYED and referenced explicitly from the
           ConnectionTemplate, NOT implicit: nodify:Connection derives from
           Shape (not Control), and WPF does not apply implicit styles from
           window resources to non-Control elements inside a DataTemplate.
           The previous implicit version of this style silently never
           applied, which is exactly why connections stopped hiding when
           their nodes were filtered out ("lines going to nowhere" bug,
           chris's screenshots 2026-07-10). Fade animation stays disabled;
           hide/show is a plain instant Visibility binding. -->
      <Style x:Key="ConnectionLineStyle" TargetType="nodify:Connection">
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
        <Style.Triggers>
          <!-- Same danger red as the Purge button / Empty-layer highlight
               toggle below, rather than a second unrelated red. -->
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Stroke" Value="#c62828" />
            <Setter Property="StrokeDashArray" Value="0" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Modern button style -->
      <Style x:Key="ModernButton" TargetType="Button">
        <Setter Property="Background" Value="#3a3a3a" />
        <Setter Property="Foreground" Value="#eee" />
        <Setter Property="BorderBrush" Value="#555" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="17,7" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="6"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#4a4a4a" />
                  <Setter Property="BorderBrush" Value="#888" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Background" Value="#2a2a2a" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Nodify editor area -->
    <Grid x:Name="CanvasArea" Grid.Row="0" Background="#0e0e0e">
      <!-- Pan/zoom-tracking grid. History of failed approaches, so nobody
           retries them: a static wallpaper (never moved with the canvas);
           moving the transform onto the Rectangle's RenderTransform with
           an oversized fixed Rectangle (grid vanished: the pan offset is
           unbounded world-space px and pushes any finite rectangle
           off-screen, unlike a brush transform which just re-phases the
           infinite tile pattern); a pre-rasterized bitmap tile in a tiled
           ImageBrush (invisible in practice: 1px hairlines at ~1.4%
           effective alpha do not survive bitmap rescaling at non-1x zoom,
           and CachingHint does nothing for ImageBrush anyway). Current
           shape is the alpha-2 vector DrawingBrush that provably rendered
           at every zoom level, with two changes: its Transform binds
           straight to Nodify's own ViewportTransform (the exact transform
           the editor applies to child controls: one shared transform
           object, no converter churn, cannot drift out of sync with the
           nodes), and RenderOptions.CachingHint=Cache (which the docs
           scope to DrawingBrush/VisualBrush) caches the rasterized tile
           in video memory and reuses it across transform changes (pans
           unconditionally, zooms within the 0.5x..2x thresholds) instead
           of re-tessellating the vector tile every tick, which was the
           original sluggishness. -->
      <Rectangle x:Name="GridBackground" Opacity="0.15" IsHitTestVisible="False">
        <Rectangle.Fill>
          <DrawingBrush Viewport="0,0,60,60" ViewportUnits="Absolute" TileMode="Tile"
                        Transform="{Binding ViewportTransform, ElementName=Editor}"
                        RenderOptions.CachingHint="Cache"
                        RenderOptions.CacheInvalidationThresholdMinimum="0.5"
                        RenderOptions.CacheInvalidationThresholdMaximum="2.0">
            <DrawingBrush.Drawing>
              <DrawingGroup>
                <GeometryDrawing Geometry="M 0,0 L 0,60 M 0,0 L 60,0">
                  <GeometryDrawing.Pen>
                    <!-- #30 alpha (was #18): grid confirmed working live but
                         read too faint (chris, 2026-07-11) -- doubled line
                         alpha rather than widening, keeps hairline look. -->
                    <Pen Brush="#30ffffff" Thickness="1" />
                  </GeometryDrawing.Pen>
                </GeometryDrawing>
              </DrawingGroup>
            </DrawingBrush.Drawing>
          </DrawingBrush>
        </Rectangle.Fill>
      </Rectangle>

      <nodify:NodifyEditor x:Name="Editor"
                            Background="Transparent"
                            ItemsSource="{Binding Nodes}"
                            Connections="{Binding Connections}"
                            PendingConnection="{Binding PendingConnection}"
                            RemoveConnectionCommand="{Binding RemoveConnectionCommand}"
                            DisconnectConnectorCommand="{Binding DisconnectConnectorCommand}"
                            MinWidth="1500" MinHeight="400"
                            AutoPanEdgeDistance="40"
                            AutoPanSpeed="30"
                            Focusable="True">

        <nodify:NodifyEditor.ItemContainerStyle>
          <Style TargetType="nodify:ItemContainer">
            <Setter Property="Location" Value="{Binding Location}" />
            <Setter Property="ActualSize" Value="{Binding Size, Mode=OneWayToSource}" />
            <Setter Property="IsDraggable" Value="False" />
            <Setter Property="IsSelected" Value="{Binding IsSelected}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
            <Style.Triggers>
              <!-- Header "containers" are explicitly sized to fence the
                   current bounding box of their side's visible nodes
                   (LayerEditorViewModel.ComputeContainerBounds), and sit
                   behind real nodes (added first in the Nodes collection,
                   plus a negative ZIndex here as a second guarantee) so
                   they never obscure or intercept clicks meant for the
                   actual layer nodes on top of them. -->
              <DataTrigger Binding="{Binding IsHeader}" Value="True">
                <Setter Property="Width" Value="{Binding Size.Width}" />
                <Setter Property="Height" Value="{Binding Size.Height}" />
                <Setter Property="Panel.ZIndex" Value="-1" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </nodify:NodifyEditor.ItemContainerStyle>

        <nodify:NodifyEditor.ItemTemplate>
          <DataTemplate DataType="{x:Type local:LayerNodeViewModel}">
            <Grid>
              <!-- Source/Target canvas "containers": chris wanted these as
                   a light fence/window frame around the currently-visible
                   nodes on each side, not a small fixed label. They pan and
                   zoom with the canvas since they're regular items in
                   the same Nodes collection (see LayerNodeViewModel.IsHeader).
                   The big background fill is IsHitTestVisible=False so
                   clicks/marquee-select pass through to the canvas in the
                   "empty" parts of the fenced area; only the title bar strip
                   is actually clickable. -->
              <Grid Visibility="{Binding IsHeader, Converter={StaticResource BoolToVis}}">
                <Border CornerRadius="10"
                        Background="#14ffffff"
                        BorderBrush="#555"
                        BorderThickness="1.5"
                        IsHitTestVisible="False" />
                <Border VerticalAlignment="Top"
                        Height="34"
                        CornerRadius="10,10,0,0"
                        Background="#33000000"
                        Cursor="Hand"
                        ToolTip="Target: click to select a different standard template"
                        MouseLeftButtonUp="OnHeaderClick">
                  <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="#ccc" />
                    <TextBlock Text="{Binding Subtitle}" FontSize="12" Foreground="#999"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Border>
              </Grid>

              <nodify:StateNode IsConnected="True" Content="{Binding}"
                                 Visibility="{Binding IsHeader, Converter={StaticResource InvBoolToVis}}"
                                 ContextMenuOpening="OnNodeContextMenuOpening">
                <!-- Placeholder menu, repopulated in OnNodeContextMenuOpening.
                     It must exist here: WPF's ContextMenuService only raises
                     ContextMenuOpening on elements that already HAVE a
                     ContextMenu, so a handler that tries to create the menu
                     inside that event without a placeholder never fires at
                     all (the original right-click-does-nothing bug). -->
                <nodify:StateNode.ContextMenu>
                  <ContextMenu />
                </nodify:StateNode.ContextMenu>
                <nodify:StateNode.ContentTemplate>
                  <DataTemplate DataType="{x:Type local:LayerNodeViewModel}">
                    <TextBlock Text="{Binding Name}"
                               Foreground="#222"
                               FontFamily="Fira Sans"
                               FontSize="11"
                               FontWeight="Medium"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </DataTemplate>
                </nodify:StateNode.ContentTemplate>
              </nodify:StateNode>
            </Grid>
          </DataTemplate>
        </nodify:NodifyEditor.ItemTemplate>

        <nodify:NodifyEditor.ConnectionTemplate>
          <DataTemplate DataType="{x:Type local:LayerConnectionViewModel}">
            <nodify:Connection Style="{StaticResource ConnectionLineStyle}"
                                Source="{Binding Source.Anchor, Mode=OneWay}"
                                Target="{Binding Target.Anchor, Mode=OneWay}"
                                Stroke="{Binding Stroke, Converter={StaticResource ColorStringToBrush}}"
                                StrokeDashArray="{Binding StrokeDashCollection}"
                                ArrowSize="0,0"
                                SourceOffset="0,0"
                                TargetOffset="0,0"
                                PreviewMouseDown="OnConnectionPreviewMouseDown"
                                ContextMenuOpening="OnConnectionContextMenuOpening">
              <!-- Placeholder menu, repopulated in the Opening handler; see
                   the StateNode.ContextMenu comment above for why it must
                   pre-exist. -->
              <nodify:Connection.ContextMenu>
                <ContextMenu />
              </nodify:Connection.ContextMenu>
            </nodify:Connection>
          </DataTemplate>
        </nodify:NodifyEditor.ConnectionTemplate>

        <nodify:NodifyEditor.PendingConnectionTemplate>
          <DataTemplate DataType="{x:Type local:PendingConnectionViewModel}">
            <nodify:PendingConnection StartedCommand="{Binding StartCommand}"
                                      CompletedCommand="{Binding FinishCommand}"
                                      Stroke="#FFE6A817"
                                      StrokeThickness="2.5"
                                      StrokeDashArray="4,3" />
          </DataTemplate>
        </nodify:NodifyEditor.PendingConnectionTemplate>
      </nodify:NodifyEditor>

      <!-- Floating filter panel (top-left, legend + toggles) -->
      <Border Grid.Row="0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="25,25,0,0"
              Padding="14,12"
              CornerRadius="8"
              Background="#882a2a2a"
              BorderBrush="#666"
              BorderThickness="1"
              Panel.ZIndex="10"
              Effect="{StaticResource PanelShadow}">
        <StackPanel Orientation="Vertical">
          <TextBlock Text="Legend"
                     FontSize="18" FontWeight="Bold"
                     Foreground="#e6e6e6" />
          <TextBlock Text="Visibility Toggle"
                     FontSize="13"
                     Foreground="#777"
                     Margin="0,0,0,10" />

          <ToggleButton Content="Exact Match"
                        Background="#008300"
                        IsChecked="{Binding IsExactNameVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Margin="0,0,0,5"
                        Style="{StaticResource FilterToggleButton}" />

          <ToggleButton Content="Memory Match"
                        Background="#3987e5"
                        IsChecked="{Binding IsMemoryMatchVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Margin="0,0,0,5"
                        Style="{StaticResource FilterToggleButton}" />

          <ToggleButton Content="Heuristic Match"
                        Background="#c98500"
                        IsChecked="{Binding IsHeuristicMatchVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Margin="0,0,0,5"
                        Style="{StaticResource FilterToggleButton}" />

          <ToggleButton Content="Manual Match"
                        Background="#9085e9"
                        IsChecked="{Binding IsManualMatchVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Margin="0,0,0,5"
                        Style="{StaticResource FilterToggleButton}" />

          <ToggleButton Content="Unmatched"
                        Background="#888"
                        IsChecked="{Binding IsUnmatchedVisible}"
                        Cursor="Hand"
                        Width="150" Height="30"
                        Style="{StaticResource FilterToggleButton}" />

          <!-- Empty layer actions -->
          <Rectangle Height="1" Fill="#555" Margin="0,10" />

          <TextBlock Text="Empty Layers"
                     FontSize="13"
                     Foreground="#777"
                     Margin="0,0,0,8" />

          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ToggleButton Grid.Column="0"
                          Content="Highlight"
                          IsChecked="{Binding IsEmptyHighlighted}"
                          Style="{StaticResource FilterToggleButton}"
                          Background="#c62828"
                          Width="80" Height="32"
                          Cursor="Hand" />

            <Button Grid.Column="2"
                    Content="Purge"
                    Command="{Binding PurgeUnusedCommand}"
                    Style="{StaticResource ModernButton}"
                    Background="#c62828"
                    Foreground="White"
                    Width="80" Height="32"
                    Cursor="Hand" />
          </Grid>

          <!-- Property matching section -->
          <Rectangle Height="1" Fill="#555" Margin="0,10" />

          <TextBlock Text="Property Matching"
                     FontSize="13"
                     Foreground="#777"
                     Margin="0,0,0,8" />

          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Match Color"
                       Foreground="#aaa" FontSize="11"
                       VerticalAlignment="Center" Width="100" />
            <ToggleButton Style="{StaticResource SlideToggle}"
                          IsChecked="{Binding IsMatchColorEnabled}" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Match Linetype"
                       Foreground="#aaa" FontSize="11"
                       VerticalAlignment="Center" Width="100" />
            <ToggleButton Style="{StaticResource SlideToggle}"
                          IsChecked="{Binding IsMatchLinetypeEnabled}" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Match Lineweight"
                       Foreground="#aaa" FontSize="11"
                       VerticalAlignment="Center" Width="100" />
            <ToggleButton Style="{StaticResource SlideToggle}"
                          IsChecked="{Binding IsMatchLineweightEnabled}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Floating Target Filter panel (top-right), same visual weight as
           the Legend panel, but every toggle is the same neutral grey
           (checked = brighter, unchecked = dimmer, via FilterToggleButton's
           existing opacity animation) since these are smart-group tags, not
           match-type categories. The list is entirely dynamic: only
           categories the current template's target layers actually
           populate ever show up (see LayerEditorViewModel.ApplyLayerDictionary,
           Core.LayerCategorizer), so an empty panel (no dictionary
           installed, or nothing matched) stays hidden rather than showing
           an empty box. -->
      <Border Grid.Row="0"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,25,25,25"
              Padding="14,12"
              CornerRadius="8"
              Background="#882a2a2a"
              BorderBrush="#666"
              BorderThickness="1"
              Panel.ZIndex="10"
              MaxHeight="{Binding ActualHeight, ElementName=CanvasArea, Converter={StaticResource SubtractDouble}, ConverterParameter=50}"
              Visibility="{Binding HasTargetFilters, Converter={StaticResource BoolToVis}}"
              Effect="{StaticResource PanelShadow}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Vertical">
            <TextBlock Text="Target Filter"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#e6e6e6" />
            <TextBlock Text="Visibility Toggle"
                       FontSize="13"
                       Foreground="#777"
                       Margin="0,0,0,10" />
          </StackPanel>

          <!-- Top-aligned + MaxHeight (bound to the canvas area's actual
               height, minus margin) makes the panel shrink to fit a short
               list, matching the Legend panel's tight look, instead of
               always stretching to the window's full height with empty
               ScrollViewer space below a short list. Still caps + scrolls
               once the list genuinely exceeds that height. -->
          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
              <!-- All On/Off now lives on the same "table" as the toggles
                   below it (chris, 2026-07-10) rather than in the fixed
                   header above the ScrollViewer. Scrolls out of view
                   with the rest of the list, which is fine per chris.
                   Special-cased with brand color (matches Apply & Remember)
                   rather than the neutral grey of the per-category toggles,
                   since it's a master action, not a category. -->
              <Button Content="All On/Off"
                      Command="{Binding ToggleAllTargetFiltersCommand}"
                      Style="{StaticResource ModernButton}"
                      Background="#4682b4"
                      Foreground="White"
                      HorizontalAlignment="Stretch"
                      Height="30"
                      Margin="0,0,0,5"
                      Cursor="Hand">
                <Button.Effect>
                  <DropShadowEffect Color="#4682b4" Opacity="0.35" BlurRadius="8" ShadowDepth="2" />
                </Button.Effect>
              </Button>

              <ItemsControl ItemsSource="{Binding TargetFilters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type local:TargetFilterViewModel}">
                    <ToggleButton Content="{Binding Name}"
                                  Background="{Binding GroupColor, Converter={StaticResource ColorStringToBrush}}"
                                  IsChecked="{Binding IsChecked}"
                                  Cursor="Hand"
                                  HorizontalAlignment="Stretch"
                                  Height="30"
                                  Margin="0,0,0,5"
                                  Style="{StaticResource FilterToggleButton}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- Status bar + action buttons -->
    <Border Grid.Row="1" Background="#2d2d2d" Padding="12,7">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Guidance line -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Foreground="#aaa"
                   FontFamily="Fira Sans"
                   FontSize="15"
                   Text="Drag from a source → standard layer to map. Click a connection to remove it. Scroll to zoom. Middle-drag to pan."
                   Margin="0,0,0,4" />

        <!-- Status + build version + action buttons -->
        <StackPanel Grid.Row="1" Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <TextBlock x:Name="StatusText"
                     Foreground="#aaa"
                     FontFamily="Fira Sans"
                     FontSize="15"
                     VerticalAlignment="Center">
            Ready
          </TextBlock>
          <TextBlock x:Name="VersionText"
                     Foreground="#555"
                     FontFamily="Fira Sans"
                     FontSize="15"
                     VerticalAlignment="Center"
                     Margin="14,0,0,0" />
        </StackPanel>

        <Button Grid.Row="1" Grid.Column="1" Content="Apply"
                Style="{StaticResource ModernButton}"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                Click="OnApply" />
        <Button Grid.Row="1" Grid.Column="2" Content="Apply &amp; Remember"
                Style="{StaticResource ModernButton}"
                Foreground="White"
                Background="#4682b4"
                BorderBrush="#5a9ec4"
                VerticalAlignment="Center"
                IsDefault="True"
                Click="OnApplyAndSave">
          <Button.Effect>
            <DropShadowEffect Color="#4682b4" Opacity="0.35" BlurRadius="10" ShadowDepth="3" />
          </Button.Effect>
        </Button>
      </Grid>
    </Border>
  </Grid>
</Window>
<Window x:Class="AcLayerStandardizer.UI.TemplateSwitchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Switch Template"
        Width="440" Height="220"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        Foreground="#ccc"
        FontFamily="Fira Sans"
        FontSize="14"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        MouseDown="Window_MouseDown">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               Foreground="#ccc"
               FontSize="15"
               Margin="0,0,0,12">
      <Run Text="You have existing mappings. What should happen to them when switching to the new template?" />
    </TextBlock>

    <StackPanel Grid.Row="1" Orientation="Vertical">
      <Button Content="Preserve mappings by name"
              Height="34"
              Margin="0,0,0,8"
              Cursor="Hand"
              Click="OnPreserve">
        <Button.Style>
          <Style TargetType="Button">
            <Setter Property="Background" Value="#4682b4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#5a9ec4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="6"
                          Padding="16,6">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#5a9ec4" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </Button.Style>
      </Button>

      <Button Content="Discard mappings and start fresh"
              Height="34"
              Margin="0,0,0,8"
              Cursor="Hand"
              Click="OnDiscard">
        <Button.Style>
          <Style TargetType="Button">
            <Setter Property="Background" Value="#c62828" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#e53935" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="6"
                          Padding="16,6">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#e53935" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </Button.Style>
      </Button>

      <Button Content="Cancel"
              Height="34"
              Cursor="Hand"
              IsCancel="True"
              Click="OnCancel">
        <Button.Style>
          <Style TargetType="Button">
            <Setter Property="Background" Value="#3a3a3a" />
            <Setter Property="Foreground" Value="#eee" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="6"
                          Padding="16,6">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#4a4a4a" />
                      <Setter Property="BorderBrush" Value="#888" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </Button.Style>
      </Button>
    </StackPanel>
  </Grid>
</Window>

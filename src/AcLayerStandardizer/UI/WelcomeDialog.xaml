<Window x:Class="AcLayerStandardizer.UI.WelcomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layer Standardizer"
        Width="560" Height="480"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="12"
        ResizeMode="CanResizeWithGrip"
        Background="#1a1a1a"
        Foreground="#e6e6e6">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/AcLayerStandardizer;component/UI/DarkTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4">
      Welcome to Layer Standardizer
    </TextBlock>
    <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,8" LineHeight="20" Foreground="#999">
      This tool helps you standardize drawing layer names and properties
      against a reference file (DWG/DWS). Set your reference and memory file below,
       then open the visual mapping editor to connect your layers.
    </TextBlock>

    <StackPanel Grid.Row="2" Margin="4,0,0,16">
      <TextBlock Foreground="#e53935" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,2">
        THIS IS BETA SOFTWARE.
      </TextBlock>
      <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
        <TextBlock Foreground="#e53935" FontWeight="Bold" Text="•" Margin="12,0,6,0" />
        <TextBlock Foreground="#e53935" FontWeight="Bold" TextWrapping="Wrap" Text="DO NOT USE ON PRODUCTION WORK." />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
        <TextBlock Foreground="#e53935" FontWeight="Bold" Text="•" Margin="12,0,6,0" />
        <TextBlock Foreground="#e53935" FontWeight="Bold" TextWrapping="Wrap" Text="BACK UP YOUR FILES BEFORE USING." />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
        <TextBlock Foreground="#e53935" FontWeight="Bold" Text="•" Margin="12,0,6,0" />
        <TextBlock Foreground="#e53935" FontWeight="Bold" TextWrapping="Wrap" Text="USE AT YOUR OWN RISK/DISCRETION." />
      </StackPanel>
    </StackPanel>

    <Border Grid.Row="3" BorderBrush="#444" BorderThickness="1" Padding="16" CornerRadius="4"
            Background="#242424" Margin="0,0,0,16">
      <StackPanel>
        <!-- Reference File -->
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Reference File:" VerticalAlignment="Center" FontWeight="SemiBold" />
          <TextBlock Grid.Column="1" x:Name="TemplateLabel" VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" ToolTipService.ShowDuration="30000"
                     Margin="0,0,8,0" />
          <Button Grid.Column="2" Content="Browse..." Padding="12,4" Click="BrowseTemplate_Click" />
        </Grid>

        <!-- Memory File -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Memory File:" VerticalAlignment="Center" FontWeight="SemiBold" />
          <TextBlock Grid.Column="1" x:Name="MemoryLabel" VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" ToolTipService.ShowDuration="30000"
                     Margin="0,0,8,0" />
          <Button Grid.Column="2" Content="Browse..." Padding="12,4" Click="BrowseMemory_Click" />
        </Grid>
      </StackPanel>
    </Border>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
      <Button Content="Open Visual Mappings Editor" Width="224" Height="34"
              FontSize="13" FontWeight="SemiBold"
              Click="OpenMappingsEditor_Click" />
    </StackPanel>

    <TextBlock Grid.Row="5" x:Name="StatusLine" Foreground="#888"
               Text="Tip: set a reference file first, then open the editor."
               Margin="0,16,0,0" TextWrapping="Wrap" />
  </Grid>
</Window>
